# KIS Open API (기존 kis-auto-standalone .env에서 복사)
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_TYPE=01  # 01=실전, 02=모의

# Anthropic Claude API (새로 발급 필요)
ANTHROPIC_API_KEY=sk-ant-...

# DART 전자공시 (기존 OPENDART_API_KEY 그대로 사용)
OPENDART_API_KEY=your_dart_api_key

# Discord Webhook (새 채널용 Webhook URL)
SWING_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
